# Database
DATABASE_URL=postgresql://localhost/reelmaker_development

# Redis
REDIS_URL=redis://localhost:6379/0

# Ollama (offline AI)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# App
APP_HOST=localhost:3000

# Google OAuth (for YouTube)
# Get from: https://console.cloud.google.com
# Enable: YouTube Data API v3
# Scopes: email, profile, https://www.googleapis.com/auth/youtube.upload
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Facebook OAuth (for Instagram)
# Get from: https://developers.facebook.com
# Required permissions: instagram_basic, instagram_content_publish, pages_read_engagement
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# TikTok OAuth
# Get from: https://developers.tiktok.com
# Required scopes: user.info.basic, video.upload, video.publish
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
