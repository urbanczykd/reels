<div class="max-w-4xl mx-auto px-4 py-10">
  <div class="flex items-start justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-white"><%= @clip.title %></h1>
      <div class="flex items-center gap-3 mt-2">
        <span class="px-2 py-0.5 rounded-full text-xs font-medium
          <%= @clip.ready? ? 'bg-green-900 text-green-300' :
              @clip.failed? ? 'bg-red-900 text-red-300' :
              @clip.processing? ? 'bg-yellow-900 text-yellow-300' :
              'bg-gray-700 text-gray-400' %>">
          <%= @clip.status.humanize %>
        </span>
        <span class="text-gray-500 text-sm"><%= @clip.duration %>s · <%= @clip.transition_effect.humanize %> transition</span>
      </div>
    </div>
    <div class="flex gap-2">
      <% if @clip.failed? || @clip.pending? %>
        <%= button_to "Regenerate", generate_clip_path(@clip), method: :post,
            class: "bg-yellow-600 hover:bg-yellow-500 text-white px-4 py-2 rounded-lg text-sm" %>
      <% end %>
      <%= button_to "Delete", clip_path(@clip), method: :delete,
          data: { turbo_confirm: "Delete this clip?" },
          class: "bg-red-900/50 hover:bg-red-900 text-red-300 px-4 py-2 rounded-lg text-sm" %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Video Preview -->
    <div class="lg:col-span-1">
      <div class="bg-gray-800 rounded-xl overflow-hidden aspect-[9/16] max-h-96 lg:max-h-full flex items-center justify-center">
        <% if @clip.video.attached? %>
          <video controls class="w-full h-full object-contain" style="max-height: 600px;">
            <source src="<%= url_for(@clip.video) %>" type="video/mp4">
          </video>
        <% elsif @clip.processing? || @clip.pending? %>
          <div class="text-center p-8">
            <div class="text-4xl mb-2"><%= @clip.processing? ? "🎬" : "⏳" %></div>
            <p class="text-gray-400 text-sm"><%= @clip.processing? ? "Rendering..." : "Queued..." %></p>
          </div>
        <% elsif @clip.failed? %>
          <div class="text-center p-8">
            <div class="text-4xl mb-4">❌</div>
            <p class="text-red-400">Generation failed</p>
            <% if @clip.error_message %>
              <p class="text-gray-600 text-xs mt-2"><%= @clip.error_message %></p>
            <% end %>
          </div>
        <% else %>
          <div class="text-center p-8">
            <div class="text-4xl mb-4">⏳</div>
            <p class="text-gray-400">Queued for generation</p>
          </div>
        <% end %>
      </div>

      <!-- Progress bar (pending or processing) -->
      <% if @clip.pending? || @clip.processing? %>
        <div id="progress-card" class="mt-4 bg-gray-800 rounded-xl p-5">
          <div class="flex justify-between items-center mb-2">
            <span id="progress-message" class="text-sm text-gray-300">
              <%= @clip.pending? ? "Waiting in queue..." : "Generating your reel..." %>
            </span>
            <span id="progress-pct" class="text-sm font-mono text-indigo-400">
              <%= @clip.generation_progress %>%
            </span>
          </div>
          <div class="w-full bg-gray-700 rounded-full overflow-hidden" style="height:8px">
            <div id="progress-bar"
                 style="width:<%= @clip.generation_progress %>%;height:8px;border-radius:9999px;background:#6366f1;transition:width 0.7s ease-out"></div>
          </div>
          <div class="flex justify-between mt-3 text-xs">
            <span id="stage-caption" style="color:<%= @clip.generation_progress >= 20 ? '#818cf8' : '#4b5563' %>">✦ AI caption</span>
            <span id="stage-ffmpeg"  style="color:<%= @clip.generation_progress >= 30 ? '#818cf8' : '#4b5563' %>">✦ Video render</span>
            <span id="stage-attach"  style="color:<%= @clip.generation_progress >= 95 ? '#818cf8' : '#4b5563' %>">✦ Finalise</span>
          </div>
        </div>
      <% end %>

      <!-- Image Grid -->
      <div class="mt-4">
        <p class="text-gray-500 text-sm mb-2"><%= @clip.images.count %> images</p>
        <div class="grid grid-cols-5 gap-1">
          <% @clip.images.each_with_index do |img, i| %>
            <div class="relative aspect-square bg-gray-700 rounded overflow-hidden">
              <%= image_tag img, class: "w-full h-full object-cover" %>
              <span class="absolute top-0 left-0 bg-black/50 text-white text-xs px-1"><%= i + 1 %></span>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Details & Upload -->
    <div class="lg:col-span-2 space-y-6">
      <!-- AI Generated Content -->
      <% if @clip.ai_caption.present? %>
        <div class="bg-gray-800 rounded-xl p-6">
          <h2 class="text-sm font-medium text-gray-400 mb-3">✨ AI Generated Caption</h2>
          <p class="text-white"><%= @clip.ai_caption %></p>
          <% if @clip.ai_hashtags.present? %>
            <p class="text-indigo-400 text-sm mt-3 font-mono"><%= @clip.ai_hashtags %></p>
          <% end %>
        </div>
      <% end %>

      <% if @clip.soundtrack %>
        <div class="bg-gray-800 rounded-xl p-6">
          <h2 class="text-sm font-medium text-gray-400 mb-3">🎵 Background Music</h2>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-indigo-900/50 rounded-lg flex items-center justify-center">🎵</div>
            <div>
              <div class="text-white font-medium"><%= @clip.soundtrack.name %></div>
              <% if @clip.soundtrack.duration_label %>
                <div class="text-gray-500 text-xs"><%= @clip.soundtrack.duration_label %></div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Upload to Social -->
      <div class="bg-gray-800 rounded-xl p-6">
        <h2 class="text-lg font-semibold text-white mb-4">Publish to Social Media</h2>

        <% platforms = [
          { key: "instagram", name: "Instagram Reels", icon: "📸", provider: "facebook", color: "from-pink-600 to-purple-600" },
          { key: "tiktok",    name: "TikTok",          icon: "🎵", provider: "tiktok",        color: "from-gray-900 to-gray-700" },
          { key: "youtube",   name: "YouTube Shorts",  icon: "▶️",  provider: "google_oauth2", color: "from-red-700 to-red-600" }
        ] %>

        <div class="space-y-3">
          <% platforms.each do |platform| %>
            <% account = current_user.social_account_for(platform[:provider]) %>
            <% result = @clip.upload_results[platform[:key]] %>
            <div class="flex items-center justify-between bg-gray-900 rounded-lg p-4">
              <div class="flex items-center gap-3">
                <span class="text-2xl"><%= platform[:icon] %></span>
                <div>
                  <div class="font-medium text-white text-sm"><%= platform[:name] %></div>
                  <div class="text-xs text-gray-500">
                    <% if account %>
                      Connected as <%= account.username %>
                    <% else %>
                      Not connected
                    <% end %>
                  </div>
                </div>
              </div>
              <div>
                <% if result&.dig("status") == "success" %>
                  <span class="text-green-400 text-sm flex items-center gap-1">
                    ✓ Published
                    <% if result["url"] %>
                      <a href="<%= result["url"] %>" target="_blank" class="text-indigo-400 underline ml-1">View</a>
                    <% end %>
                  </span>
                <% elsif result&.dig("status") == "error" %>
                  <span class="text-red-400 text-sm" title="<%= result['error'] %>">✗ Failed</span>
                <% elsif !account %>
                  <%= link_to "Connect", social_accounts_path, class: "text-xs bg-gray-700 hover:bg-gray-600 text-gray-300 px-3 py-1.5 rounded-md" %>
                <% elsif !@clip.ready? %>
                  <span class="text-gray-600 text-xs">Video not ready</span>
                <% else %>
                  <%= button_to "Upload", upload_to_social_clip_path(@clip),
                      params: { platform: platform[:key] },
                      class: "text-xs bg-indigo-600 hover:bg-indigo-500 text-white px-3 py-1.5 rounded-md" %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>

        <% unless current_user.social_accounts.any? %>
          <div class="mt-4 text-center">
            <%= link_to "Connect Social Accounts →", social_accounts_path, class: "text-indigo-400 hover:text-indigo-300 text-sm" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<% if @clip.processing? || @clip.pending? %>
  <script>
    (function() {
      const bar     = document.getElementById('progress-bar');
      const pct     = document.getElementById('progress-pct');
      const msg     = document.getElementById('progress-message');
      const caption = document.getElementById('stage-caption');
      const ffmpeg  = document.getElementById('stage-ffmpeg');
      const attach  = document.getElementById('stage-attach');

      const indigo = '#818cf8', muted = '#4b5563';

      function setProgress(p, message) {
        if (bar) bar.style.width = p + '%';
        if (pct) pct.textContent = p + '%';
        if (msg) msg.textContent = message;
        if (caption) caption.style.color = p >= 20 ? indigo : muted;
        if (ffmpeg)  ffmpeg.style.color  = p >= 30 ? indigo : muted;
        if (attach)  attach.style.color  = p >= 95 ? indigo : muted;
      }

      function poll() {
        fetch('<%= progress_clip_path(@clip) %>', { headers: { 'Accept': 'application/json' } })
          .then(r => r.json())
          .then(data => {
            setProgress(data.progress, data.message);
            if (data.status === 'ready' || data.status === 'failed') {
              window.location.reload();
            } else {
              setTimeout(poll, 500);
            }
          })
          .catch(() => setTimeout(poll, 1000));
      }

      setTimeout(poll, 500);
    })();
  </script>
<% end %>
