<div class="max-w-xl mx-auto px-4 py-10">
  <h1 class="text-2xl font-bold text-white mb-8">Upload Soundtrack</h1>

  <%= form_with model: @soundtrack, class: "space-y-6" do |f| %>
    <% if @soundtrack.errors.any? %>
      <div class="bg-red-900/50 border border-red-700 rounded-lg p-4">
        <% @soundtrack.errors.full_messages.each do |msg| %>
          <p class="text-red-300 text-sm"><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <div>
      <%= f.label :name, class: "block text-sm font-medium text-gray-300 mb-1" %>
      <%= f.text_field :name,
          class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500",
          placeholder: "e.g. Upbeat Summer Vibes" %>
    </div>

    <div>
      <%= f.label :description, class: "block text-sm font-medium text-gray-300 mb-1" %>
      <%= f.text_field :description,
          class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500",
          placeholder: "Optional notes about this track" %>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-300 mb-2">Audio File</label>
      <div class="border-2 border-dashed border-gray-600 rounded-xl p-8 text-center hover:border-indigo-500 transition-colors cursor-pointer"
           onclick="document.getElementById('audio-input').click()">
        <div class="text-4xl mb-2">🎵</div>
        <p class="text-gray-400">Click to browse audio file</p>
        <p class="text-gray-600 text-sm mt-1">MP3, M4A, WAV, OGG up to 50MB</p>
      </div>
      <%= f.file_field :audio_file, id: "audio-input", accept: "audio/*", class: "hidden" %>
      <p id="audio-filename" class="text-gray-500 text-sm mt-2 hidden"></p>
    </div>

    <div class="flex gap-4">
      <%= f.submit "Upload Soundtrack",
          class: "flex-1 bg-indigo-600 hover:bg-indigo-500 text-white font-medium py-3 rounded-lg cursor-pointer transition-colors" %>
      <%= link_to "Cancel", soundtracks_path, class: "px-6 py-3 text-gray-400 hover:text-white" %>
    </div>
  <% end %>
</div>

<script>
  document.getElementById('audio-input').addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (file) {
      const el = document.getElementById('audio-filename');
      el.textContent = file.name + ' (' + (file.size / 1024 / 1024).toFixed(1) + ' MB)';
      el.classList.remove('hidden');
    }
  });
</script>
