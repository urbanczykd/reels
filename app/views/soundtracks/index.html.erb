<div class="max-w-4xl mx-auto px-4 py-10">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-white">Soundtracks</h1>
      <p class="text-gray-400 text-sm mt-1">Pick a track for your reels or upload your own</p>
    </div>
    <%= link_to "Upload Soundtrack", new_soundtrack_path, class: "bg-indigo-600 hover:bg-indigo-500 text-white px-4 py-2 rounded-lg text-sm font-medium" %>
  </div>

  <%
    global_tracks = @soundtracks.select(&:global?)
    my_tracks     = @soundtracks.reject(&:global?)
  %>

  <!-- Default tracks -->
  <% if global_tracks.any? %>
    <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Default Tracks</h2>
    <div class="space-y-3 mb-8">
      <% global_tracks.each do |soundtrack| %>
        <div class="bg-gray-800 border border-gray-700 rounded-xl p-5 flex items-center gap-4">
          <div class="w-12 h-12 bg-indigo-900/40 rounded-xl flex items-center justify-center text-2xl flex-shrink-0">
            🎵
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2">
              <span class="font-medium text-white"><%= soundtrack.name %></span>
              <span class="text-xs bg-indigo-900/60 text-indigo-400 px-2 py-0.5 rounded-full">Default</span>
            </div>
            <div class="flex items-center gap-3 mt-0.5">
              <% if soundtrack.duration_label %>
                <span class="text-gray-500 text-xs">⏱ <%= soundtrack.duration_label %></span>
              <% end %>
              <span class="text-gray-500 text-xs"><%= soundtrack.description %></span>
            </div>
          </div>
          <% if soundtrack.audio_file.attached? %>
            <audio controls class="h-8 w-44 flex-shrink-0">
              <source src="<%= url_for(soundtrack.audio_file) %>" type="<%= soundtrack.audio_file.content_type %>">
            </audio>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- User's own tracks -->
  <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">My Uploads</h2>
  <% if my_tracks.any? %>
    <div class="space-y-3">
      <% my_tracks.each do |soundtrack| %>
        <div class="bg-gray-800 rounded-xl p-5 flex items-center gap-4">
          <div class="w-12 h-12 bg-purple-900/40 rounded-xl flex items-center justify-center text-2xl flex-shrink-0">
            🎶
          </div>
          <div class="flex-1 min-w-0">
            <div class="font-medium text-white truncate"><%= soundtrack.name %></div>
            <div class="flex items-center gap-3 mt-0.5">
              <% if soundtrack.duration_label %>
                <span class="text-gray-500 text-xs">⏱ <%= soundtrack.duration_label %></span>
              <% end %>
              <% if soundtrack.description.present? %>
                <span class="text-gray-500 text-xs truncate"><%= soundtrack.description %></span>
              <% end %>
              <span class="text-gray-600 text-xs"><%= soundtrack.clips.count %> clip<%= soundtrack.clips.count == 1 ? "" : "s" %></span>
            </div>
          </div>
          <div class="flex items-center gap-3 flex-shrink-0">
            <% if soundtrack.audio_file.attached? %>
              <audio controls class="h-8 w-44">
                <source src="<%= url_for(soundtrack.audio_file) %>" type="<%= soundtrack.audio_file.content_type %>">
              </audio>
            <% end %>
            <%= button_to "Delete", soundtrack_path(soundtrack), method: :delete,
                data: { turbo_confirm: "Delete \"#{soundtrack.name}\"? Clips using it will lose their audio." },
                class: "text-red-400 hover:text-red-300 text-sm px-3 py-1.5 rounded-lg border border-red-900 hover:border-red-700" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-gray-800/50 border border-dashed border-gray-700 rounded-xl p-10 text-center">
      <div class="text-4xl mb-3">🎶</div>
      <p class="text-gray-500 text-sm">No personal uploads yet</p>
      <%= link_to "Upload a track →", new_soundtrack_path, class: "text-indigo-400 hover:text-indigo-300 text-sm mt-2 inline-block" %>
    </div>
  <% end %>
</div>
