<div class="min-h-screen flex items-center justify-center bg-gray-950 px-4">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <div class="text-5xl mb-3">🎬</div>
      <h1 class="text-3xl font-bold text-white">ReelMaker</h1>
      <p class="text-gray-400 mt-1">Sign in to your account</p>
    </div>

    <div class="bg-gray-900 rounded-2xl p-8 border border-gray-800">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="space-y-4">
          <div>
            <%= f.label :email, class: "block text-sm text-gray-400 mb-1" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email",
                class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 text-white placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-indigo-500",
                placeholder: "you@example.com" %>
          </div>
          <div>
            <%= f.label :password, class: "block text-sm text-gray-400 mb-1" %>
            <%= f.password_field :password, autocomplete: "current-password",
                class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 text-white placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-indigo-500",
                placeholder: "••••••••" %>
          </div>
          <div class="flex items-center gap-2">
            <%= f.check_box :remember_me, class: "rounded border-gray-600 text-indigo-600" %>
            <%= f.label :remember_me, class: "text-sm text-gray-400" %>
          </div>
          <%= f.submit "Sign In", class: "w-full bg-indigo-600 hover:bg-indigo-500 text-white font-medium py-3 rounded-lg cursor-pointer transition-colors mt-2" %>
        </div>
      <% end %>

      <p class="text-center text-gray-500 text-sm mt-6">
        Don't have an account?
        <%= link_to "Sign up →", new_registration_path(resource_name), class: "text-indigo-400 hover:text-indigo-300" %>
      </p>
    </div>
  </div>
</div>
