<!DOCTYPE html>
<html class="h-full bg-gray-950">
  <head>
    <title>ReelMaker</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="csrf-param" content="<%= request_forgery_protection_token %>">
    <meta name="csrf-token" content="<%= form_authenticity_token %>">
    <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="h-full">
    <% if user_signed_in? %>
      <nav class="bg-gray-900 border-b border-gray-800">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex items-center justify-between h-16">
            <div class="flex items-center gap-8">
              <a href="/" class="text-white font-bold text-xl tracking-tight">
                🎬 ReelMaker
              </a>
              <div class="hidden md:flex items-center gap-4">
                <%= link_to "Dashboard", root_path, class: "text-gray-300 hover:text-white text-sm" %>
                <%= link_to "My Clips", clips_path, class: "text-gray-300 hover:text-white text-sm" %>
                <%= link_to "New Clip", new_clip_path, class: "bg-indigo-600 hover:bg-indigo-500 text-white text-sm px-3 py-1.5 rounded-md" %>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <%= link_to "Connections", social_accounts_path, class: "text-gray-300 hover:text-white text-sm" %>
              <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-gray-400 hover:text-white text-sm" %>
            </div>
          </div>
        </div>
      </nav>
    <% end %>

    <main class="min-h-screen bg-gray-950 text-white">
      <% if notice %>
        <div class="max-w-7xl mx-auto px-4 pt-4">
          <div class="bg-green-900/50 border border-green-700 text-green-300 px-4 py-3 rounded-lg" role="alert">
            <%= notice %>
          </div>
        </div>
      <% end %>
      <% if alert %>
        <div class="max-w-7xl mx-auto px-4 pt-4">
          <div class="bg-red-900/50 border border-red-700 text-red-300 px-4 py-3 rounded-lg" role="alert">
            <%= alert %>
          </div>
        </div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
