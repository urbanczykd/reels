<div class="max-w-7xl mx-auto px-4 py-10">
  <div class="mb-10">
    <h1 class="text-3xl font-bold text-white">Welcome back, <%= current_user.name.presence || current_user.email.split("@").first %>!</h1>
    <p class="text-gray-400 mt-1">Create stunning reels from your photos in seconds.</p>
  </div>

  <!-- Quick Actions -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-10">
    <%= link_to new_clip_path, class: "group bg-indigo-600 hover:bg-indigo-500 rounded-xl p-6 flex items-center gap-4 transition-colors" do %>
      <div class="text-4xl">🎬</div>
      <div>
        <div class="font-semibold text-white text-lg">Create New Reel</div>
        <div class="text-indigo-200 text-sm">Upload up to 20 images</div>
      </div>
    <% end %>

    <%= link_to social_accounts_path, class: "group bg-gray-800 hover:bg-gray-700 rounded-xl p-6 flex items-center gap-4 transition-colors" do %>
      <div class="text-4xl">🔗</div>
      <div>
        <div class="font-semibold text-white text-lg">Social Connections</div>
        <div class="text-gray-400 text-sm">
          <%= current_user.social_accounts.count %> / 3 platforms connected
        </div>
      </div>
    <% end %>

    <%= link_to clips_path, class: "group bg-gray-800 hover:bg-gray-700 rounded-xl p-6 flex items-center gap-4 transition-colors" do %>
      <div class="text-4xl">📁</div>
      <div>
        <div class="font-semibold text-white text-lg">My Clips</div>
        <div class="text-gray-400 text-sm"><%= current_user.clips.count %> reels created</div>
      </div>
    <% end %>
  </div>

  <!-- Recent Clips -->
  <h2 class="text-xl font-semibold text-white mb-4">Recent Clips</h2>
  <% if @clips.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% @clips.each do |clip| %>
        <%= link_to clip_path(clip), class: "bg-gray-800 hover:bg-gray-750 rounded-xl overflow-hidden transition-colors group" do %>
          <div class="bg-gray-700 aspect-[9/16] max-h-48 flex items-center justify-center relative">
            <% if clip.video.attached? %>
              <video class="w-full h-full object-cover" muted>
                <source src="<%= url_for(clip.video) %>" type="video/mp4">
              </video>
            <% else %>
              <div class="text-gray-500 text-4xl">
                <%= clip.status == "processing" ? "⏳" : "🎞️" %>
              </div>
            <% end %>
            <div class="absolute top-2 right-2">
              <span class="px-2 py-0.5 rounded-full text-xs font-medium
                <%= clip.ready? ? 'bg-green-900 text-green-300' :
                    clip.failed? ? 'bg-red-900 text-red-300' :
                    clip.processing? ? 'bg-yellow-900 text-yellow-300' :
                    'bg-gray-700 text-gray-400' %>">
                <%= clip.status.humanize %>
              </span>
            </div>
          </div>
          <div class="p-4">
            <div class="font-medium text-white truncate"><%= clip.title %></div>
            <div class="text-gray-500 text-xs mt-1"><%= time_ago_in_words(clip.created_at) %> ago</div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="bg-gray-800 rounded-xl p-12 text-center">
      <div class="text-5xl mb-4">🎬</div>
      <p class="text-gray-400 mb-4">No clips yet. Create your first reel!</p>
      <%= link_to "Create Clip", new_clip_path, class: "bg-indigo-600 hover:bg-indigo-500 text-white px-6 py-2 rounded-lg inline-block" %>
    </div>
  <% end %>
</div>
